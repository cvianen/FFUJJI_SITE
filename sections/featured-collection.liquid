{%- comment -%}
  This is a required section for the Shopify Theme Store.
  It is available in the "Featured Collection" section in the theme editor.

  Theme Store required settings
  - Collection

  Theme Store optional settings
  - Heading: title of the featured collection section
{%- endcomment -%}
{%- liquid
  assign section_color = section.settings.color_scheme
  assign collection = collections[section.settings.collection]
  assign product_limit = section.settings.grid | times: section.settings.rows
  assign products_per_row = section.settings.grid
  assign products_per_row_mobile = section.settings.grid_mobile | plus: 0
  assign show_view_all = section.settings.show_view_all
  assign view_all_text = 'collections.general.view_all' | t
  assign counter = 0
  assign grid_cols = 12

  case products_per_row
    when 2
      assign desktop_col_span = 'lg:col-span-6'
    when 3
      assign desktop_col_span = 'lg:col-span-4'
    when 4
      assign desktop_col_span = 'lg:col-span-3'
    when 5
      assign grid_cols = 10
      assign desktop_col_span = 'lg:col-span-2'
  endcase

  case products_per_row_mobile
    when 1
      assign mobile_col_span = 'col-span-2'
    when 2
      assign mobile_col_span = 'col-span-1'
  endcase

  assign desktop_grid_class = 'lg:grid-cols-' | append: grid_cols
-%}

<section id="fc-section-{{ section.id }}" class="featured-collection border-t-grid border-grid-color" data-color-scheme="{{ section_color }}">
  {% if section.settings.title != '' %}
    {%- render 'section-title',
      title: section.settings.title,
      show_link: show_view_all,
      link_text: view_all_text,
      link_url: collection.url,
      section_color: section_color
    -%}
  {% endif %}

  <style>
    @media (max-width: 1023px) {
      #fc-scroll-{{ section.id }} { padding-left: 16px; scroll-padding-left: 16px; }
      #fc-scroll-{{ section.id }}::-webkit-scrollbar { display: none; }
      #fc-list-{{ section.id }} {
        display: flex !important;
        overflow: visible !important;
        width: max-content !important;
        gap: 8px !important;
        background: transparent !important;
        padding: 0 !important;
      }
      #fc-list-{{ section.id }} > li {
        flex: 0 0 84vw !important;
        width: 84vw !important;
        min-width: 84vw !important;
        max-width: 84vw !important;
        scroll-snap-align: start;
        border: none !important;
      }
      #fc-list-{{ section.id }} > li[aria-hidden="true"] { display: none !important; }
    }
    @media (min-width: 1024px) {
      #fc-scroll-{{ section.id }} { overflow: visible !important; }
    }
  </style>

  <div id="fc-scroll-{{ section.id }}" class="bg-scheme-background" style="overflow-x:auto; overflow-y:visible; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch; scrollbar-width:none;">
    <ul id="fc-list-{{ section.id }}" class="grid grid-cols-2 {{ desktop_grid_class }} gap-gutter bg-border">
      {% for product in collection.products limit: product_limit %}
        {%- assign counter = counter | plus: 1 -%}
        <li class="{{ mobile_col_span }} {{ desktop_col_span }} bg-scheme-background text-scheme-text fc-product-item"
            data-section-id="{{ section.id }}"
            data-title="{{ product.title | escape }}"
            data-image="{{ product.featured_image | image_url: width: 120 }}"
            data-price="{% if settings.currency_code_enabled == true %}{{ product.price | money_with_currency }}{% else %}{{ product.price | money }}{% endif %}"
            data-variant-id="{{ product.first_available_variant.id }}"
            data-variant-title="{{ product.first_available_variant.title | escape }}"
            data-available="{{ product.available }}">
          {%- render 'product-grid-item',
              product: product,
              section_color: section_color,
              products_per_row: products_per_row,
              products_per_row_mobile: products_per_row_mobile,
              responsive_image_counter: forloop.index
          -%}
        </li>
      {% else %}
        {% for i in (1..product_limit) %}
          <li class="{{ mobile_col_span }} {{ desktop_col_span }} bg-scheme-background text-scheme-text">
            <a href="#" class="featured-collection-item block">
              {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
              <div class="border-b-grid border-grid-color {% unless settings.fill_image_to_border_edge %}}p-2 lg:p-4{% endunless %}">
                <div class="bg-placeholder-bg">
                  {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg placeholder-svg--small' }}
                </div>
              </div>
              <div class="flex justify-between p-4">
                <p class="w-3/4">{{ 'homepage.onboarding.product_title' | t }}</p>
                <p>{% if settings.currency_code_enabled == true %}{{ 1999 | money_with_currency }}{% else %}{{ 1999 | money }}{% endif %}</p>
              </div>
            </a>
          </li>
        {% endfor %}
      {% endfor %}
      {%- if collection.products.size > 0 -%}
        {%- liquid
          assign items_on_last_row = counter | modulo: products_per_row
          assign col_span = grid_cols | divided_by: products_per_row
          assign placeholder_width = products_per_row | minus: items_on_last_row | times: col_span
          assign items_on_last_row_mobile = counter | modulo: products_per_row_mobile
          assign col_span_mobile = 2 | divided_by: products_per_row_mobile
          assign placeholder_width_mobile = products_per_row_mobile | minus: items_on_last_row_mobile | times: col_span_mobile
        -%}
        {%- if items_on_last_row != 0 -%}
          <li class="none absolute lg:static lg:block lg:col-span-{{ placeholder_width }} bg-scheme-background" aria-hidden="true" role="presentation"></li>
        {%- endif -%}
        {%- if items_on_last_row_mobile != 0 -%}
          <li class="block lg:none lg:absolute col-span-{{ placeholder_width_mobile }} bg-scheme-background" aria-hidden="true" role="presentation"></li>
        {%- endif -%}
      {%- endif -%}
    </ul>
  </div>

  {%- render 'view-all' with
    title: section.settings.title,
    show_link: show_view_all,
    link_text: view_all_text,
    link_url: collection.url,
    section_color: section_color
  -%}
</section>

{% if template.name == 'product' %}
<!-- Sticky quick-add bar for featured collection {{ section.id }} -->
<div id="fc-sticky-{{ section.id }}"
     style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:100; transform:translateY(100%); transition:transform 0.3s ease; background:#fff; border-top:1px solid #e5e5e5;">
  <div style="display:flex; align-items:center; padding:12px 24px; gap:16px; max-width:100%;">
    <img id="fc-sticky-img-{{ section.id }}" src="" alt=""
         style="width:48px; height:48px; object-fit:cover; flex-shrink:0;">
    <div style="flex:1; min-width:0; overflow:hidden;">
      <p id="fc-sticky-title-{{ section.id }}"
         style="font-size:0.875rem; font-weight:500; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:#030303;"></p>
      <p id="fc-sticky-variant-{{ section.id }}"
         style="font-size:0.75rem; margin:0; color:#888; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></p>
    </div>
    <p id="fc-sticky-price-{{ section.id }}"
       style="font-size:0.875rem; font-weight:500; flex-shrink:0; margin:0; color:#030303;"></p>
    <button id="fc-sticky-btn-{{ section.id }}"
            style="flex-shrink:0; padding:12px 24px; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:500; cursor:pointer; background:#030303; color:#fff; border:none;">
      ADD TO BAG
    </button>
  </div>
</div>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var bar = document.getElementById('fc-sticky-' + sectionId);
  var section = document.getElementById('fc-section-' + sectionId);
  if (!bar || !section) return;

  var imgEl     = document.getElementById('fc-sticky-img-' + sectionId);
  var titleEl   = document.getElementById('fc-sticky-title-' + sectionId);
  var variantEl = document.getElementById('fc-sticky-variant-' + sectionId);
  var priceEl   = document.getElementById('fc-sticky-price-' + sectionId);
  var btnEl     = document.getElementById('fc-sticky-btn-' + sectionId);

  var currentVariantId = null;
  var isLoading = false;

  function setProduct(li) {
    var d = li.dataset;
    imgEl.src = d.image || '';
    imgEl.alt = d.title || '';
    titleEl.textContent = d.title || '';
    variantEl.textContent = (d.variantTitle && d.variantTitle !== 'Default Title') ? d.variantTitle : '';
    priceEl.textContent = d.price || '';
    currentVariantId = d.variantId || null;
    btnEl.disabled = d.available === 'false';
  }

  function showBar() {
    bar.style.display = 'block';
    requestAnimationFrame(function() {
      bar.style.transform = 'translateY(0)';
    });
  }

  function hideBar() {
    bar.style.transform = 'translateY(100%)';
    setTimeout(function() {
      if (bar.style.transform === 'translateY(100%)') bar.style.display = 'none';
    }, 300);
  }

  function updateVisibility() {
    var rect = section.getBoundingClientRect();
    var footer = document.querySelector('footer');
    var footerRect = footer ? footer.getBoundingClientRect() : null;
    var sectionVisible = rect.bottom > 0 && rect.top < window.innerHeight;
    var footerVisible = footerRect ? footerRect.top < window.innerHeight : false;
    if (sectionVisible && !footerVisible) {
      showBar();
    } else {
      hideBar();
    }
  }

  // Set first product as default
  var firstItem = section.querySelector('.fc-product-item[data-variant-id]');
  if (firstItem) setProduct(firstItem);

  // Hover on product items
  var items = section.querySelectorAll('.fc-product-item[data-variant-id]');
  items.forEach(function(li) {
    li.addEventListener('mouseenter', function() { setProduct(li); });
  });

  // Scroll listener
  window.addEventListener('scroll', updateVisibility, { passive: true });
  updateVisibility();

  // Add to cart
  btnEl.addEventListener('click', function() {
    if (isLoading || !currentVariantId) return;
    isLoading = true;
    btnEl.textContent = '• • •';
    btnEl.disabled = true;

    fetch(window.theme.routes.cart_add_url + '.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: parseInt(currentVariantId), quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      document.dispatchEvent(new CustomEvent('cart:open'));
      document.dispatchEvent(new CustomEvent('theme:cart:change'));
      return fetch(window.theme.routes.cart_url + '.js').then(function(r) { return r.json(); });
    })
    .then(function(cart) {
      document.querySelectorAll('[data-cart-count]').forEach(function(el) {
        el.textContent = cart.item_count;
      });
    })
    .finally(function() {
      isLoading = false;
      btnEl.textContent = 'ADD TO BAG';
      btnEl.disabled = false;
    });
  });
})();
</script>
{% endif %}

{% schema %}
  {
    "name": "Featured collection",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Featured collection"
      },
      {
        "id": "collection",
        "type": "collection",
        "label": "Collection"
      },
      {
        "type": "range",
        "id": "grid",
        "label": "Products per row",
        "min": 2,
        "max": 5,
        "step": 1,
        "default": 3
      },
      {
        "type": "range",
        "id": "rows",
        "label": "Rows",
        "min": 1,
        "max": 5,
        "step": 1,
        "default": 2
      },
      {
        "type": "select",
        "id": "grid_mobile",
        "label": "Products per row - mobile",
        "options": [
            { "value": "1", "label": "1"},
            { "value": "2", "label": "2"}
        ],
        "default":   "1"
      },
      {
        "type": "checkbox",
        "id": "show_view_all",
        "label": {
          "en": "Show 'View all' link"
        },
        "default": false
      },
      {
        "type":      "header",
        "content":   "Color"
      },
      {
        "type": "select",
        "id": "color_scheme",
        "label": "Color scheme",
        "options": [
            { "value": "primary", "label": "Primary"},
            { "value": "secondary", "label": "Secondary"},
            { "value": "tertiary", "label": "Tertiary"}
        ],
        "default":   "primary"
      }
    ],
    "presets": [
      {
        "name": "Featured collection"
      }
    ]
  }
{% endschema %}
