{%- assign section_color = 'primary' -%}
{%- assign video_url = section.settings.video_url -%}

<style>
  #PasswordNewsletterForm-email::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }
  #logInWithPasswordBtn {
    text-decoration: none;
    transition: text-decoration-color 0.3s ease;
  }
  #logInWithPasswordBtn:hover {
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: rgba(255, 255, 255, 0.7);
    text-decoration-thickness: 1px;
  }
  #password-submit-btn {
    background: rgba(255, 255, 255, 0.18);
    transition: background 0.3s ease;
  }
  #password-submit-btn:hover {
    background: rgba(255, 255, 255, 0.28);
  }
</style>

<section class="relative flex items-center justify-center overflow-hidden" style="width: 100vw; height: 100vh;" data-color-scheme="{{ section_color }}">

  {%- if video_url != blank -%}
  <video autoplay muted loop playsinline
    class="absolute inset-0 w-full h-full object-cover z-0"
    style="pointer-events:none;">
    <source src="{{ video_url }}" type="video/mp4">
  </video>
  {%- endif -%}

  <div class="absolute inset-0 z-10" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>

  <div class="relative z-20 flex flex-col items-center text-center w-full max-w-xs" style="color: white; text-shadow: 0 0 30px rgba(0,0,0,0.95), 0 0 60px rgba(0,0,0,0.7), 0 1px 4px rgba(0,0,0,0.9); padding: 2.5rem 2rem;">

    <div style="margin-bottom: 3.5rem;">
      {% if section.settings.logo != blank %}
        {%- assign logo = section.settings.logo -%}
        {% capture image_size %}{{ section.settings.logo_max_width }}x{% endcapture %}
        <img src="{{ logo | img_url: image_size }}"
            class="mx-auto"
            srcset="{{ logo | img_url: image_size }} 1x, {{ logo | img_url: image_size, scale: 2 }} 2x"
            alt="{{ logo.alt | default: shop.name }}"
        >
      {% else %}
        <h1 class="font-heading text-4xl tracking-widest" style="color:white;">{{ shop.name }}</h1>
      {% endif %}
    </div>

    <div class="mb-10">
      <button id="logInWithPasswordBtn" data-password-toggle @click="$store.drawer.passwordOpen = true"
        class="cursor-pointer inline-flex items-center gap-2 px-8 py-3 text-sm tracking-widest uppercase"
        style="color:white; background:transparent; border:none;">
        <span class="inline-block w-3 h-3" aria-hidden="true">{%- render 'icon-lock' -%}</span>
        {{ 'general.password_page.password_link' | t }}
      </button>
    </div>

    {% if section.settings.newsletter_enable %}
    <div class="w-full">
      {% if section.settings.newsletter_form_heading != blank %}
        <div class="text-sm mb-4" style="color:rgba(255,255,255,0.7);">{{ section.settings.newsletter_form_heading }}</div>
      {%- endif -%}

      {% form 'customer', id: 'ContactPassword', class: 'contact-form' %}
        <input type="hidden" name="contact[tags]" value="prospect, password page">
        {%- if form.posted_successfully? -%}
          <p style="color:white;">{{ 'general.password_page.signup_form_success' | t }}</p>
        {%- else -%}
          <input type="email"
            class="w-full bg-transparent pb-2 mb-4 text-center focus:outline-none"
            style="border-bottom: 1px solid white; color:white;"
            name="contact[email]"
            id="PasswordNewsletterForm-email"
            placeholder="{{ section.settings.newsletter_placeholder | escape }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email">
          <button type="submit" id="password-submit-btn"
            class="w-full px-8 py-3 text-sm tracking-widest uppercase cursor-pointer"
            style="color:white; border:none;">
            {{ section.settings.newsletter_button_text | escape }}
          </button>
        {%- endif -%}
        {%- if form.errors contains 'email' -%}
          <span class="block mt-2 text-sm" style="color:rgba(255,120,120,1);">{{ form.errors.messages['email'] }}</span>
        {%- endif -%}
      {% endform %}
    </div>
    {% endif %}

  </div>
</section>

{% schema %}
  {
    "name": "Content",
    "settings": [
      {
        "type": "text",
        "id": "video_url",
        "label": "Background video URL (MP4)",
        "info": "Upload video via Shopify Admin → Content → Files, then paste the URL here."
      },
      {
        "type": "range",
        "id": "overlay_opacity",
        "min": 0,
        "max": 80,
        "step": 5,
        "unit": "%",
        "label": "Dark overlay opacity",
        "default": 35
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image (use white version)"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "min": 20,
        "max": 450,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 200
      },
      {
        "type": "header",
        "content": "Newsletter"
      },
      {
        "type": "checkbox",
        "id": "newsletter_enable",
        "label": "Show newsletter signup",
        "default": true
      },
      {
        "type": "richtext",
        "id": "newsletter_form_heading",
        "label": "Newsletter form heading",
        "default": "<p>Be the first to know when we launch.</p>"
      },
      {
        "type": "text",
        "id": "newsletter_placeholder",
        "label": "Email placeholder",
        "default": "Email address"
      },
      {
        "type": "text",
        "id": "newsletter_button_text",
        "label": "Button text",
        "default": "Submit"
      }
    ]
  }
{% endschema %}
