{% comment %}theme-check-disable TemplateLength{% endcomment %}
{%- liquid
  assign section_color = section.settings.color_scheme
  assign enable_video_looping = section.settings.enable_video_looping
  assign two_images_per_row = section.settings.two_images_per_row
  assign main_media_ratio = product.featured_media.preview_image.aspect_ratio | default: 1
  assign first_image_full_width = false
  if section.settings.first_image_full_width and section.settings.two_images_per_row
    assign first_image_full_width = true
  endif


  case section.settings.desktop_image_width
    when 'one-third'
      assign content_width_desktop = 'lg:col-span-8'
      assign desc_max_width = '33.33%'
      if section.settings.desktop_image_position == 'right'
        assign image_width_desktop = 'lg:col-start-9 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-4'
      endif
    when 'one-half'
      assign content_width_desktop = 'lg:col-span-6'
      assign desc_max_width = '50%'
      if section.settings.desktop_image_position == 'right'
        assign image_width_desktop = 'lg:col-start-7 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-6'
      endif
    when 'three-fifths'
      assign content_width_desktop = 'lg:col-span-5'
      assign desc_max_width = '58.33%'
      if section.settings.desktop_image_position == 'right'
        assign image_width_desktop = 'lg:col-start-6 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-7'
      endif
    when 'two-thirds'
      assign content_width_desktop = 'lg:col-span-4'
      assign desc_max_width = '66.67%'
      if section.settings.desktop_image_position == 'right'
        assign image_width_desktop = 'lg:col-start-5 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-8'
      endif
  endcase

  if two_images_per_row == true and product.media.size > 1
    assign left_over = product.media.size | modulo: 2
  endif

  assign negative_margin = false
  if settings.fill_image_to_border_edge
    assign negative_margin = true
  endif

-%}

<section class="grid grid-cols-1 lg:grid-cols-12 lg:bg-border grid-flow-row-dense lg:gap-gutter border-t-grid border-grid-color product-page-section" x-data="ThemeSection_{{ section.id | handleize | replace: '-', '_' }}()" x-init="mounted()" data-section-id="{{ section.id }}" data-alpine-id="{{ section.id | handleize | replace: '-', '_' }}" data-section-type="product" data-enable-history-state="true" data-enable-image-zoom={{ section.settings.enable_image_zoom | json }} data-variant-image-behaviour="{{ section.settings.variant_image_behaviour }}" data-color-scheme="{{ section_color }}">
  {%- liquid
    assign current_variant = product.selected_or_first_available_variant
    assign featured_media = current_variant.featured_media | default: product.featured_media
    assign has_interactive_media = false
    assign image_index = 0
  -%}
  {%- for media in product.media -%}
    {%- if media.media_type != 'image' -%}
      {%- assign has_interactive_media = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  <div class="lg:col-span-12 grid grid-cols-1 lg:grid-cols-12 lg:gap-gutter product-media-content-wrapper">
  <div class="relative {% if product.media.size > 1 %}pb-8{% endif %} lg:pb-0 product-media-container bg-scheme-background text-scheme-text {{ image_width_desktop }} {% unless settings.fill_image_to_border_edge %}border-b-grid border-grid-color lg:border-0{% endunless %} lg:flex lg:gap-4" data-product-single-media-group>
    {% if product.media.size > 1 %}
<div class="hidden lg:block lg:w-24 lg:shrink-0 lg:pt-4"
     x-data="{
       canDown: false,
       canUp: false,
       check() {
         let el = this.$refs.tlist;
         this.canDown = el.scrollTop + el.clientHeight < el.scrollHeight - 4;
         this.canUp = el.scrollTop > 4;
       },
       scrollDown() { this.$refs.tlist.scrollBy({ top: 146, behavior: 'smooth' }); },
       scrollUp() { this.$refs.tlist.scrollBy({ top: -146, behavior: 'smooth' }); }
     }"
     x-init="$nextTick(() => check())">
  <div class="relative">
    <ul x-ref="tlist"
        @scroll="check()"
        class="flex flex-col gap-1"
        style="max-height: calc(4 * 140px + 3 * 6px); overflow-y: scroll; scrollbar-width: none; -ms-overflow-style: none;">
      {%- assign thumb_i = 0 -%}
      {%- if featured_media != null and featured_media.media_type == 'image' -%}
        {%- assign thumb_i = thumb_i | plus: 1 -%}
        <li style="height: 140px; flex-shrink: 0; overflow: hidden;">
          <button type="button"
            class="product-thumb is-normal block w-full h-full"
            data-thumb-media-id="{{ featured_media.id }}">
            <img src="{{ featured_media | image_url: width: 200 }}"
                 alt="{{ featured_media.alt | escape }}"
                 class="block w-full h-full"
                 style="object-fit: cover;"
                 loading="lazy">
          </button>
        </li>
      {%- endif -%}
      {%- for media in product.media -%}
        {%- unless featured_media and media.id == featured_media.id -%}
          {%- if media.media_type == 'image' -%}
            {%- assign thumb_i = thumb_i | plus: 1 -%}
            <li style="height: 140px; flex-shrink: 0; overflow: hidden;">
              <button type="button"
                class="product-thumb is-normal block w-full h-full"
                data-thumb-media-id="{{ media.id }}">
                <img src="{{ media | image_url: width: 200 }}"
                     alt="{{ media.alt | escape }}"
                     class="block w-full h-full"
                     style="object-fit: cover;"
                     loading="lazy">
              </button>
            </li>
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
    </ul>
    <button x-show="canDown" @click="scrollDown()"
            style="display:none; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.85))"
            class="absolute bottom-0 left-0 right-0 flex justify-center items-end pb-1 pt-8 cursor-pointer">
      <span class="w-4 h-4 block">{%- render 'icon-chevron-down' -%}</span>
    </button>
    <button x-show="canUp" @click="scrollUp()"
            style="display:none; background: linear-gradient(to top, transparent, rgba(255,255,255,0.85))"
            class="absolute top-0 left-0 right-0 flex justify-center items-start pt-1 pb-8 cursor-pointer"
            >
      <span class="w-4 h-4 block" style="transform: scaleY(-1)">{%- render 'icon-chevron-down' -%}</span>
    </button>
  </div>
</div>
{% endif %}
<div class="splide splide--product js-product-splide lg:flex-1 {% if negative_margin %}lg:-mb-theme-width{% endif %}" style="--main-media-ratio: {{ main_media_ratio }};" data-drag-disabled="{{ has_interactive_media }}"{% if product.media.size > 1 %}data-slideshow-enabled="true"{% endif %} >    
  <div class="transition-max-height splide__track {% if settings.fill_image_to_border_edge %}border-b-grid border-grid-color lg:border-0{% endif %} {% unless settings.fill_image_to_border_edge %}lg:p-4{% endunless %} {% if negative_margin %}lg:border-b-grid lg:border-grid-color{% endif %}">
      <ul class="splide__list lg:w-full">
        {%- if featured_media != null -%}
          {%- assign media = featured_media -%}
          <li  class="{% if left_over > 0 or first_image_full_width %}col-span-2{% endif %} splide__slide bg-scheme-background" data-index="0" data-first-media>
            {%- render 'product-media',
              media: media,
              image_index: image_index,
              section_color: section_color,
              enable_video_looping: enable_video_looping
            -%}
          </li>
          {%- if media.media_type == 'image' -%}
            {%- assign image_index = image_index | plus: 1 -%}
          {%- endif -%}
        {%- endif -%}
        {% for media in product.media %}
            {%- liquid
              assign full_width_image = false
              if left_over > 0 and forloop.first and featured_media == null
                assign full_width_image = true
              elsif first_image_full_width and forloop.first and featured_media == null
                assign full_width_image = true
              elsif first_image_full_width and forloop.last and left_over == 0
                assign full_width_image = true
              elsif first_image_full_width and product.media.size == 2
                assign full_width_image = true
              endif
            -%}
            {%- unless media.id == featured_media.id -%}
            <li {% if featured_media == null and forloop.first %}data-first-media{% endif %} class="{% if full_width_image %}col-span-2{% endif %} splide__slide bg-scheme-background" data-index="{% if featured_media == null %}{{ forloop.index0 }}{% else %}{{ forloop.index }}{% endif %}">
              {%- render 'product-media',
                media: media,
                image_index: image_index,
                section_color: section_color,
                enable_video_looping: enable_video_looping
              -%}
            </li>
            {%- if media.media_type == 'image' -%}
              {%- assign image_index = image_index | plus: 1 -%}
            {%- endif -%}
            {% endunless %}
          {% endfor %}
        </ul>
      </div>
      {% assign first_3d_model = product.media | where: "media_type", "model" | first %}
      <div class="js-enabled lg:hidden splide__arrows text-scheme-text absolute right-0 {% if first_3d_model %}bottom-slide-arrows{% endif %} mr-1 lg:mr-4 text-right mt-2">
        <button class="splide__arrow splide__arrow--prev w-8">
          <span class="visually-hidden">{{ 'sections.slideshow.previous_slide' | t }}</span>
          <span class="block">{% render 'icon-previous' %}</span>
        </button>
        <button class="splide__arrow splide__arrow--next w-8">
          <span class="visually-hidden">{{ 'sections.slideshow.next_slide' | t }}</span>
          <span class="block">{% render 'icon-next' %}</span>
        </button>
      </div>
      {%- if first_3d_model -%}
        <div class="section-x-padding text-center">
          <button aria-label="{{ 'products.product.view_in_space_label' | t }}"
                  class="product-single__view-in-space mt-4 mb-2 lg:my-4 w-full py-2 pl-2 pr-4 max-w-sm text-center border-text border-scheme-text"
                  data-shopify-xr
                  data-shopify-model3d-id="{{ first_3d_model.id }}"
                  data-shopify-title="{{ product.title }}"
                  data-shopify-xr-hidden>
            <span class="inline-block w-6 align-middle">{% render 'icon-3d-model' %}</span><span class="text-sm">{{ 'products.product.view_in_space' | t }}</span>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="product-content-container bg-scheme-background text-scheme-text section-x-padding {{ content_width_desktop }}" x-ref="productContent">
    <div class="lg:sticky lg:top-sticky-header py-theme product-block-area">
      {%- render 'product-form', product: product, section: section, section_color: section_color, move_description_below_media: true -%}
    </div>
  </div>
  </div>{{- '<!-- end product-media-content-wrapper -->' -}}

  {%- assign _desc_intro = product.description | split: '<h3>' | first -%}
  {%- if _desc_intro != blank -%}
  <div class="block lg:col-span-12 bg-scheme-background text-scheme-text">
    <div class="section-x-padding product-description-below pt-16 pb-theme">
      <div class="rte" style="max-width: {{ desc_max_width }}">{{ _desc_intro }}</div>
    </div>
  </div>
  {%- endif -%}

  {% unless product == empty %}
    <script type="application/json" data-product-json>
      {{ product | json }}
    </script>
    <script type="application/json" data-selected-variant-json>
      {{ current_variant | json }}
    </script>
    <script type="application/json" data-featured-media-id>
      {{ featured_media.id | json }}
    </script>
    {% if section.settings.enable_image_zoom %}
    {% assign product_image_media = product.media | where: 'media_type', 'image' %}
    <script type="application/json" data-product-images>
    {
      {% for media in product_image_media %}
        "{{ media.id }}": {
          "fullSizeUrl": {{ media | img_url: 'master' | json }},
          "width": {{ media.width | json }},
          "height": {{ media.height | json }},
          "aspectRatio": {{ media.aspect_ratio | json }},
          "alt": {{ media.alt | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    }
    </script>
    {% endif %}
    <script type="application/json" id="ModelJson-{{ section.id }}">
        {{ product.media | where: 'media_type', 'model' | json }}
    </script>
  {% endunless %}

  <!-- Mobile sticky add-to-bag bar -->
  <div id="mobile-sticky-bar-{{ section.id }}" class="lg:hidden" style="position:fixed; bottom:0; left:0; right:0; z-index:200; background:#fff; border-top:1px solid #e0e0e0; transition:transform 0.25s ease; transform:translateY(0);">
  <script>
    (function() {
      var bar = document.getElementById('mobile-sticky-bar-{{ section.id }}');
      var atcBtn = document.getElementById('addToCartButton');
      if (!bar || !atcBtn) return;
      var obs = new IntersectionObserver(function(entries) {
        bar.style.transform = entries[0].isIntersecting ? 'translateY(calc(100% + 60px))' : 'translateY(0)';
      }, { threshold: 0.1 });
      obs.observe(atcBtn);
    })();
  </script>
    <!-- Floating price badge -->
    <div style="position:absolute; top:-46px; left:50%; transform:translateX(-50%); background:#fff; border-radius:4px; padding:8px 16px; box-shadow:0 -2px 8px rgba(0,0,0,0.10); white-space:nowrap;">
      <div style="display:flex; align-items:baseline; gap:8px; justify-content:center;">
        <span x-text="formatMoney(current_variant.price)" style="font-size:1rem; font-weight:700; color:#008000;"></span>
        <s x-show="current_variant.compare_at_price > current_variant.price"
           x-text="formatMoney(current_variant.compare_at_price)"
           style="font-size:0.8rem; color:#999;"></s>
      </div>
    </div>
    <div style="display:flex; align-items:center; gap:16px; padding:14px 16px 24px;">

      <!-- Left: product name + size picker -->
      {%- assign has_size_option = false -%}
      {%- for option in product.options_with_values -%}
        {%- assign opt_lower_check = option.name | downcase -%}
        {%- if opt_lower_check == 'size' or opt_lower_check == 'maat' or opt_lower_check == 'sizes' -%}
          {%- assign has_size_option = true -%}
        {%- endif -%}
      {%- endfor -%}
      <div style="flex:1; min-width:0; {% unless has_size_option %}display:flex; align-items:center;{% endunless %}">
        <p style="font-size:0.85rem; font-weight:500; letter-spacing:0.12em; text-transform:uppercase; font-family:var(--heading-font-stack); margin:{% if has_size_option %}0 0 8px{% else %}0{% endif %}; line-height:1.4; color:#030303;">
          {{ product.title }}
        </p>

        {%- comment -%}Size picker{%- endcomment -%}
        {% for option in product.options_with_values %}
          {%- assign opt_lower = option.name | downcase -%}
          {% if opt_lower == 'size' or opt_lower == 'maat' or opt_lower == 'sizes' %}
            {%- assign size_opt_index = forloop.index0 -%}
            <div style="display:flex; gap:5px; flex-wrap:nowrap; overflow-x:auto; padding-bottom:2px; font-size:1.1rem;">
              {% for value in option.values %}
                {%- assign val_handle = value | handleize -%}
                {%- assign size_available = true -%}
                {%- if product.options.size == 1 -%}
                  {%- unless product.variants[forloop.index0].available -%}
                    {%- assign size_available = false -%}
                  {%- endunless -%}
                {%- endif -%}
                <button
                  type="button"
                  class="{% unless size_available %}line-through{% endunless %}"
                  style="padding:4px 10px; border:1px solid #ccc; font-weight:500; letter-spacing:0.12em; text-transform:uppercase; font-family:var(--heading-font-stack); background:#fff; white-space:nowrap; flex-shrink:0;"
                  :style="optionHandles[{{ size_opt_index }}] === '{{ val_handle }}' ? 'border-color:#030303; font-weight:700;' : 'border-color:#ccc; font-weight:400;'"
                  {% unless size_available %}disabled{% endunless %}
                  onclick="(function(){var e=document.getElementById('Section-{{ section.id }}-Option{{ option.position }}-{{ value | escape }}')||document.getElementById('Option{{ option.position }}-{{ value | escape }}');if(e&&!e.checked)e.click();})()">
                  {{ value }}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Right: ADD TO BAG button -->
      <button
        type="button"
        onclick="var btn=document.getElementById('addToCartButton'); if(btn&&!btn.disabled){btn.click();}"
        :disabled="!currentVariantAvailable || loading"
        style="flex-shrink:0; padding:12px 18px; font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; font-weight:500; background:transparent; color:#008000; border:none; cursor:pointer; transition:opacity 0.2s;"
        :style="(!currentVariantAvailable || loading) ? 'opacity:0.45; cursor:not-allowed;' : 'opacity:1; cursor:pointer;'">
        <span x-show="!loading && currentVariantAvailable">ADD TO CART</span>
        <span x-show="!loading && !currentVariantAvailable">SOLD OUT</span>
        <span x-show="loading">• • •</span>
      </button>

    </div>
  </div>
</section>

{%- if section.settings.enable_image_zoom -%}
  {% render 'photoswipe' %}
{%- endif -%}

{%- if section.settings.override_header_footer_color_scheme -%}
  {%- render 'header-footer-color-scheme-override', section_color: section_color -%}
{%- endif -%}

{% assign current_variant = product.selected_or_first_available_variant %}

<script type="application/ld+json">
{
  "@context": "http://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ shop.url | append: product.url | json }},
  {%- if product.featured_media -%}
    {%- assign media_size = product.featured_media.preview_image.width | append: 'x' -%}
    "image": [
      {{ product.featured_media | img_url: media_size | prepend: "https:" | json }}
    ],
  {%- endif -%}
  "description": {{ product.description | strip_html | json }},
  {%- if current_variant.sku != blank -%}
    "sku": {{ current_variant.sku | json }},
  {%- endif -%}
  "brand": {
    "@type": "Thing",
    "name": {{ product.vendor | json }}
  },
  "offers": [
    {%- for variant in product.variants -%}
      {
        "@type" : "Offer",
        {%- if variant.sku != blank -%}
          "sku": {{ variant.sku | json }},
        {%- endif -%}
        "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
        "price" : {{ variant.price | divided_by: 100.00 | json }},
        "priceCurrency" : {{ cart.currency.iso_code | json }},
        "url" : {{ shop.url | append: variant.url | json }}
      }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
  ]
}
</script>

{% schema %}
  {
    "name": "Product pages",
    "settings": [
      {
        "type": "select",
        "id": "desktop_image_width",
        "label": "Desktop image width",
        "options": [
          { "value": "one-third", "label": "One third"},
          { "value": "one-half", "label": "One half"},
          { "value": "three-fifths", "label": "Three fifths"},
          { "value": "two-thirds", "label": "Two thirds"}
        ],
        "default":   "one-half"
      },
      {
        "type": "select",
        "id": "desktop_image_position",
        "label": "Desktop image position",
        "options": [
            { "value": "left", "label": "Left"},
            { "value": "right", "label": "Right"}
        ],
        "default":   "left"
      },
      {
        "type": "checkbox",
        "id": "two_images_per_row",
        "label": "Enable two images per row on desktop",
        "default":  false,
        "info": "If there are an odd number of images, first image will be full width"
      },
      {
        "type": "checkbox",
        "id": "first_image_full_width",
        "label": "Full width first image on desktop",
        "default":  false,
        "info": "Applies only if two images per row on desktop is enabled"
      },
      {
        "type": "select",
        "id": "variant_image_behaviour",
        "label": "Variant image change behaviour",
        "options": [
            { "value": "swap", "label": "Swap with first image"},
            { "value": "scroll", "label": "Scroll to image"}
        ],
        "default":   "swap"
      },
      {
        "type": "header",
        "content": "Media",
        "info": "Learn more about [media types](https://help.shopify.com/manual/products/product-media)"
      },
      {
        "type": "checkbox",
        "id": "enable_image_zoom",
        "label": "Enable image zoom"
      },
      {
        "type": "checkbox",
        "id": "enable_video_looping",
        "label":  "Enable video looping",
        "default": false
      },
      {
        "type": "header",
        "content": "Color"
      },
      {
        "type": "select",
        "id": "color_scheme",
        "label": "Color scheme",
        "options": [
            { "value": "primary", "label": "Primary"},
            { "value": "secondary", "label": "Secondary"},
            { "value": "tertiary", "label": "Tertiary"}
        ],
        "default":   "primary"
      },
      {
        "type": "checkbox",
        "id": "override_header_footer_color_scheme",
        "label": "Use this color scheme for header and footer",
        "info": "This will only apply to the product template",
        "default": false
      }
    ],
    "blocks": [
      {
        "type": "title",
        "name": "Title",
        "limit": 1
      },
      {
        "type": "color_swatches",
        "name": "Color swatches",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Titel",
            "default": "Kleur"
          },
          {
            "type": "range",
            "id": "size",
            "label": "Grootte",
            "min": 14,
            "max": 40,
            "step": 1,
            "default": 18
          },
          {
            "type": "color",
            "id": "fallback_color",
            "label": "Fallback",
            "default": "#CCCCCC"
          }
        ]
      },
      {
        "type": "price",
        "name": "Price",
        "limit": 1
      },
      {
        "type": "variant_picker",
        "name": "Variant picker",
        "limit": 1,
        "settings": [
          {
            "type": "select",
            "id": "option_style",
            "label": "Options style",
            "options": [
              { "value": "text_underline", "label": "Text with underline"},
              { "value": "radio", "label": "Radio"},
              { "value": "buttons", "label": "Button"},
              { "value": "drop_down", "label": "Drop down"}
            ],
            "default":   "text_underline"
          },
          {
            "type": "checkbox",
            "id": "hide_option_labels",
            "label": "Hide option labels"
          }
        ]
      },
      {
        "type": "quantity_selector",
        "name": "Quantity selector",
        "limit": 1
      },
      {
        "type": "buy_buttons",
        "name": "Buy buttons",
        "limit": 1,
        "settings": [
          {
            "type": "checkbox",
            "id": "enable_payment_button",
            "label": "Show dynamic checkout button",
            "info": "Each customer will see their preferred payment method from those available on your store, such as PayPal or Apple Pay. [Learn more](https://help.shopify.com/manual/using-themes/change-the-layout/dynamic-checkout)",
            "default": true
          },
          {
            "type": "header",
            "content": "Pickup Availability"
          },
          {
            "type": "checkbox",
            "id": "show_pickup_availability",
            "label": "Show pickup availability [Learn more](https://help.shopify.com/en/manual/sell-in-person/pos-classic/shopify-pos-from-admin/buy-online-pickup-in-store#show-pickup-availability-to-your-customers)",
            "default": true
          }
        ]
