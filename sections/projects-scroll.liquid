<style>
  .projects-scroll-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 5rem 0;
  }
  .projects-scroll-item:first-child {
    padding-top: 2rem;
  }
  .projects-scroll-label {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    display: inline-block;
    margin-bottom: 1.5rem;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }
  .projects-scroll-label:hover {
    opacity: 1;
  }
  .projects-scroll-image-wrap {
    width: 100%;
    max-width: 680px;
    position: relative;
    overflow: hidden;
  }
  .projects-scroll-image-wrap a {
    display: block;
  }
  .projects-scroll-image-wrap img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s ease;
  }
  .projects-scroll-image-wrap a:hover img {
    transform: scale(1.02);
  }
  .projects-scroll-title {
    margin-top: 1.25rem;
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }
  .projects-scroll-title:hover {
    opacity: 0.9;
  }
</style>

<section class="section-x-padding py-8" data-color-scheme="{{ section.settings.color_scheme }}" data-section-type="projects-scroll">
  <div class="max-w-screen-lg mx-auto">
    {%- for block in section.blocks -%}
      {%- if block.type == 'project' -%}
        <div class="projects-scroll-item" {{ block.shopify_attributes }}>

          {%- if block.settings.season_label != blank -%}
            {%- if block.settings.link != blank -%}
              <a class="projects-scroll-label" href="{{ block.settings.link }}">{{ block.settings.season_label }}</a>
            {%- else -%}
              <span class="projects-scroll-label">{{ block.settings.season_label }}</span>
            {%- endif -%}
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            <div class="projects-scroll-image-wrap">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" aria-label="{{ block.settings.season_label | escape }}">
              {%- endif -%}
                <img
                  src="{{ block.settings.image | img_url: '1400x' }}"
                  srcset="{{ block.settings.image | img_url: '800x' }} 800w, {{ block.settings.image | img_url: '1400x' }} 1400w"
                  sizes="(min-width: 1024px) 680px, 100vw"
                  alt="{{ block.settings.image.alt | default: block.settings.season_label | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            {%- if block.settings.link != blank -%}
              <a class="projects-scroll-title" href="{{ block.settings.link }}">{{ block.settings.title }}</a>
            {%- else -%}
              <span class="projects-scroll-title">{{ block.settings.title }}</span>
            {%- endif -%}
          {%- endif -%}

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Projects scroll",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "tertiary", "label": "Tertiary" }
      ],
      "default": "primary"
    }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        {
          "type": "text",
          "id": "season_label",
          "label": "Season label",
          "info": "Small clickable label above the image (e.g. FW23, SS25)",
          "default": "FW23"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Shown below the image (e.g. The Mountain Never Sleeps)",
          "default": "Collection name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Projects scroll"
    }
  ]
}
{% endschema %}
