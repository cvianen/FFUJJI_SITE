<div class="collapsible-tab mt-8 {% if is_last %}mb-8{% endif %}" {{ block.shopify_attributes }}>
  <div class="{% if tab_counter == 0 %}border-t-grid{% endif %} -mx-2 lg:-mx-4 section-x-padding py-2 border-theme-color border-b-grid"
       x-data="{ open: {% if tab_counter == 0 %}true{% else %}false{% endif %} }"
       @product-tab-opened.window="open = ($event.detail.id === '{{ block.id }}')"
       x-cloak>
    <h2>
      <button @click="$dispatch('product-tab-opened', { id: open ? '' : '{{ block.id }}' })"
              class="font-body uppercase tracking-wider cursor-pointer flex justify-between items-center w-full text-left"
              :aria-expanded="open ? true : 'false'">
        <span class="flex items-center justify-start">
          {% if block.settings.icon != 'none' %}<span class="inline-block flex-shrink-0 w-5 h-5 mr-2">{% render 'product-icon', icon: block.settings.icon %}</span>{% endif %}
          {{ block.settings.heading }}
        </span>
        <span class="inline-block w-5 h-5" x-show="!open">{%- render 'icon-plus' %}</span>
        <span class="inline-block w-5 h-5" x-show="open">{%- render 'icon-minus' %}</span>
      </button>
    </h2>
    <div class="py-4 rte text-sm" x-show="open" id="{{ block.id }}">
      {%- if block.settings.content != blank -%}
        {{ block.settings.content }}
      {%- endif -%}
      {%- if block.settings.page.content != blank -%}
        {{ block.settings.page.content }}
      {%- endif -%}
      {%- if block.settings.tab_image != blank -%}
        <img src="{{ block.settings.tab_image | image_url: width: 1200 }}"
             alt="{{ block.settings.tab_image.alt | escape }}"
             class="w-full {% if block.settings.content != blank or block.settings.page.content != blank %}mt-4{% endif %}"
             loading="eager">
      {%- endif -%}
      {%- if block.settings.content == blank and block.settings.page == blank and block.settings.tab_image == blank -%}
        &nbsp;
      {%- endif -%}
    </div>
  </div>
  <noscript>
    <div class="rte mt-8">
      <h2>{{ block.settings.heading }}</h2>
      {{ block.settings.content }}
      {{ block.settings.page.content }}
    </div>
  </noscript>
</div>
